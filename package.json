{
  "name": "express-multipart-parser",
  "version": "1.0.0",
  "keywords": [
    "express",
    "middleware",
    "multipart",
    "form-data",
    "upload",
    "file",
    "parser",
    "form",
    "stream"
  ],
  "description": "An express middleware that parses multipart/form-data contents to req.body and req.files (for files).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "start": "ts-node example.ts",
    "dev": "ts-node-dev --clear --transpile-only --respawn --ignore-watch node_modules example.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdisaongithub/express-multipart-parser.git"
  },
  "author": "Abdisa Tsegaye",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.5.1",
    "@types/supertest": "^2.0.12",
    "express": "^4.18.2",
    "jest": "^30.3.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "files": [
    "dist"
  ]
}
